{
  "name": "e2e-testing-with-ai",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "npm run allure:generate && allure open allure-report",
    "report": "playwright test && npm run allure:open"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "typescript": "^5.9.3"
  }
}
